{
	"name": "@habiti/admin",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "dotenv -e .env.local -- sh -c \"export PATH=$(echo \\\"$PATH\\\" | sed -E 's|/private/tmp/bun-node-[^:]+:||g'); NODE_OPTIONS='--import ./instrument.server.mjs' node ./node_modules/vite/bin/vite.js dev --port 3000\"",
		"build": "vite build && cp instrument.server.mjs .output/server",
		"preview": "vite preview",
		"test": "vitest run",
		"deploy": "bun run build && wrangler deploy",
		"start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs"
	},
