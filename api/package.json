{
	"name": "@habiti/api",
	"version": "0.0.1",
	"main": "dist/index.js",
	"license": "GPL-3.0",
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"build": "tsc && bun sentry:sourcemaps",
		"start": "bun dist/index",
		"sentry:sourcemaps": "sentry-cli sourcemaps inject --org habiti --project habiti-api ./dist && sentry-cli sourcemaps upload --org habiti --project habiti-api ./dist",
		"complete-stale-pickups": "bun src/scripts/complete-stale-pickups.ts"
	},
	"dependencies": {
		"@hono/sentry": "^1.2.2",
		"@hono/zod-validator": "^0.7.6",
		"@prisma/adapter-pg": "^7.1.0",
		"@prisma/client": "7",
		"@prisma/instrumentation": "^6.7.0",
		"@sentry/bun": "^10.14.0",
		"@sentry/cli": "^2.41.1",
		"argon2": "^0.41.1",
		"axios": "^1.10.0",
		"cloudinary": "^2.9.0",
		"dotenv": "^16.4.7",
		"expo-server-sdk": "^3.15.0",
		"fs-capacitor": "^8.0.0",
		"hono": "^4.12.12",
		"jsonwebtoken": "^9.0.2",
		"loops": "^4.1.0",
		"nodemailer": "^6.10.0",
		"pg": "^8.13.1",
		"posthog-node": "^4.14.0",
		"zod": "~3.24.0"
	},
	"devDependencies": {
		"@types/bun": "^1.2.22",
		"@types/jest": "^29.5.14",
		"@types/jsonwebtoken": "^9.0.8",
		"@types/nodemailer": "^6.4.17",
		"@types/pg": "^8.11.10",
		"jest": "^29.7.0",
		"prisma": "7",
		"typescript": "^5.7.3"
	}
}
